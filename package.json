{
  "name": "cron-job-dashboard",
  "description": "A local cron dashboard with a built-in Linux desktop runtime.",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "desktop/main.cjs",
  "author": "Cron Job Dashboard",
  "scripts": {
    "postinstall": "npm --prefix backend install && npm --prefix frontend install",
    "dev": "concurrently \"npm --prefix backend run dev\" \"npm --prefix frontend run dev\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "desktop:dev": "npm run rebuild:desktop:native && concurrently -k \"VITE_API_URL=http://127.0.0.1:4100 npm --prefix frontend run dev -- --host 127.0.0.1 --strictPort\" \"wait-on http://127.0.0.1:5173 && DESKTOP_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "rebuild:desktop:native": "electron-rebuild -f -w better-sqlite3 -m backend",
    "rebuild:backend:native": "npm --prefix backend rebuild better-sqlite3",
    "build:desktop": "node scripts/build-desktop.mjs --dir",
    "dist:linux": "node scripts/build-desktop.mjs --linux deb AppImage",
    "test": "npm --prefix backend run test",
    "test:desktop-smoke": "npm run rebuild:backend:native && node scripts/desktop-smoke.mjs"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "concurrently": "^9.1.2",
    "electron": "37.10.3",
    "electron-builder": "^26.0.12",
    "wait-on": "^8.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "build": {
    "appId": "com.crondashboard.desktop",
    "productName": "Cron Job Dashboard",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "backend/src/**/*",
      "backend/package.json",
      "backend/node_modules/**/*",
      "shared/src/**/*",
      "shared/package.json",
      "frontend/dist/**/*",
      "scripts/desktop-smoke.mjs",
      "package.json"
    ],
    "asarUnpack": [
      "backend/node_modules/**/*.node"
    ],
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Utility",
      "maintainer": "Cron Job Dashboard"
    }
  }
}
